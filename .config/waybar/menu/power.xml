    <child>
      <object class="GtkMenuItem" id="reboot">
        <child>
          <object class="GtkBox">
            <property name="spacing">6</property>
            <child>
              <object class="GtkImage">
                <property name="icon-name">system-reboot-symbolic</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label">Reboot</property>
              </object>
            </child>
          </object>
        </child>
      </object>
